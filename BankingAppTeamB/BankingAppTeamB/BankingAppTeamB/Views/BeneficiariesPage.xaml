<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="BankingAppTeamB.Views.BeneficiariesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BankingAppTeamB.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
            <TextBlock Text="Beneficiaries" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Add New Beneficiary" Command="{Binding ShowAddFormCommand}" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Beneficiaries}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding IBAN}" Foreground="Gray" />
                            <TextBlock Text="{Binding BankName}" Foreground="Gray" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button Content="Use" 
                                    Command="{Binding ElementName=RootPage, Path=DataContext.UseForTransferCommand}" 
                                    CommandParameter="{Binding}" />
                            <Button Content="Delete" 
                                    Command="{Binding ElementName=RootPage, Path=DataContext.DeleteCommand}" 
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="15" Margin="0,20,0,0"
                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="10">
                <TextBlock Text="Add New Beneficiary" FontWeight="SemiBold" FontSize="18" />

                <TextBox Header="Name" Text="{Binding NewName, Mode=TwoWay}" />
                <TextBox Header="IBAN" Text="{Binding NewIBAN, Mode=TwoWay}" />
                <TextBox Header="Bank Name" Text="{Binding NewBankName, Mode=TwoWay}" />

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Button Content="Save" Command="{Binding AddCommand}" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Cancel" Click="CancelAdd_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap" 
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
    </Grid>
</Page>